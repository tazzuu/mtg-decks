Name=Vela the Night-Clad: Intimidating Machinery
Description={"ops":[{"insert":"Date of creation:\n2015"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"\nTheme:\nArtifacts matter and artifact creature beats"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"\nPower:\nAs with most of my decks, very midrange, but hard  to stop once the pieces are in play"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"\nWin conditions:\nTezzeret + artifacts = damage"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"Unblockable creature beats sometimes supplemented by things like "},{"insert":{"card-link":"Karn, Silver Golem"}},{"insert":" making my rocks into bodies"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"Vela exit-the-battlefield triggers"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"Alt-win cons like "},{"insert":{"card-link":"Revel in Riches"}},{"insert":" and "},{"insert":{"card-link":"Mirrodin Besieged"}},{"insert":" "},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"\nRules and notes:\nColorless artifact creatures only"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"Only Tezzeret allowed as a planeswalker"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"This is a work-in-progress altered deck using borderless alters done by Ryan Peneff (@CadPopCast)"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"\nChangelog:\n2020 01-11 add "},{"insert":{"card-link":"Soul-Guide Lantern"}},{"insert":" rmv "},{"insert":{"card-link":"Nihil Spellbomb"}},{"insert":" "},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 02-05 add "},{"insert":{"card-link":"Crashing Drawbridge"}},{"insert":" rmv "},{"insert":{"card-link":"Burnished Hart"}},{"insert":" "},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 02-09 add "},{"insert":{"card-link":"Unwinding Clock"}},{"insert":"  rmv "},{"insert":{"card-link":"Witching Well"}},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 04-11 add "},{"insert"