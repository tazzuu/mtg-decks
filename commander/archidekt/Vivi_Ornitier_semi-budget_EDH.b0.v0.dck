Name=Vivi Ornitier, semi-budget EDH
Description={"ops":[{"attributes":{"bold":true},"insert":"Core Concept"},{"attributes":{"header":1},"insert":"\n"},{"insert":" The deck functions as a linear Izzit spellslinger–storm shell. Your plan is to "},{"attributes":{"underline":true,"bold":true},"insert":"ramp and reduce spell costs early"},{"insert":", ensure that "},{"insert":{"card-link":"Vivi Ornitier"}},{"insert":"  can safely enter the battlefield and survive one turn, and then "},{"attributes":{"underline":true,"bold":true},"insert":"untap and combo off"},{"insert":". You run a very high density of "},{"attributes":{"underline":true,"bold":true},"insert":"replacement spells, cantrips, and pseudo-draw"},{"insert":", which continuously grow "},{"insert":{"card-link":"Vivi Ornitier"}},{"insert":" while keeping your hand full. Once your engines are online, every spell you cast essentially replaces itself or generates additional value.\n"},{"attributes":{"bold":true},"insert":"1. Early Game: Ramp, Setup, Cost Reduction"},{"attributes":{"header":2},"insert":"\n"},{"attributes":{"bold":true},"insert":"Goal:"},{"insert":" Assemble mana engines and cost reducers. Do "},{"attributes":{"underline":true,"bold":true},"insert":"not"},{"insert":" cast "},{"insert":{"card-link":"Vivi Ornitier"}},{"insert":" yet.\nKey pieces:\n\n"},{"attributes":{"bold":true},"insert":"Cost Reduction:"},{"insert":" "},{"insert":{"card-link":"Ruby Medallion"}},{"insert":", "},{"insert":{"card-link":"Helm of Awakening"}},{"insert":", "},{"insert":{"card-link":"Stormcatch Mentor"}},{"insert":", "},{"insert":{"card-link":"Artist's Talent"}},{"insert":", "},{"insert":{"card-link":"Case of the Ransacked Lab"}},{"insert":", "},{"insert":{"card-link":"Ral, Monsoon Mage // Ral, Leyline Prodigy"}},{"insert":"."},{"attributes":{"list":"bullet"},"insert":"\n"},{"attributes":{"bold":true},"insert":"Mana Engines:"},{"insert":" "},{"insert":{"card-link":"Runaway Steam-Kin"}},{"insert":", "},{"insert":{"card-link":"Storm-Kiln Artist"}},{"insert":", "},{"insert":{"card-link":"Brass's Bounty"}},{"insert":", "},{"insert":{"card-link":"Mana Geyser"}},{"insert":", "},{"insert":{"card-link":"Seething Song"}},{"insert":"."},{"attributes":{"list":"bullet"},"insert":"\n"},{"attributes":{"bold":true},"insert":"Card Advantage Engines:"},{"insert":" "},{"insert":{"card-link":"Rhystic Study"}},{"insert":", "},{"insert":{"card-link":"Archmage of Runes"}},{"insert":", "},{"insert":{"card-link":"Niv-Mizzet, Visionary"}},{"insert":", "},{"insert":{"card-link":"Niv-Mizzet, Parun"}},{"insert":"."},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"Use counters to stop real threats, not to protect value engines. Save protection for "},{"insert":{"card-link":"Vivi Ornitier"}},{"insert":".\n"},{"attributes":{"bold":true},"insert":"2."},{"insert":" "},{"attributes":{"bold":true},"insert":{"card-link":"Vivi Ornitier"}},{"attributes":{"bold":true},"insert":" Enters: “Stick Turn”"},{"attributes":{"header":2},"insert":"\n"},{"insert":"Cast "},{"insert":{"card-link":"Vivi Ornitier"}},{"insert":" only when you can leave meaningful interaction open.\nTypical sequence:\nCost reducers + mana engines in place."},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"Cast "},{"insert":{"card-link":"Vivi Ornitier"}},{"insert":"."},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"Keep up protection: "},{"insert":{"card-link":"Fierce Guardianship"}},{"insert":", "},{"insert":{"card-link":"Deflecting Swat"}},{"insert":", "},{"insert":{"card-link":"Dispel"}},{"insert":", "},{"insert":{"card-link":"Negate"}},{"insert":", "},{"insert":{"card-link":"Counterspell"}},{"insert":", "},{"insert":{"card-link":"Shore Up"}},{"insert":", "},{"insert":{"card-link":"Magic Damper"}},{"insert":", "},{"insert":{"card-link":"Swiftfoot Boots"}},{"insert":" Fierce Guardianship, Deflecting Swat, Dispel, Negate, Counterspell, Shore Up, Magic Damper, Swiftfoot Boots."},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"If Vivi survives a full rotation, the setup is complete.\n Once Vivi untaps, "},{"attributes":{"bold":true},"insert":"you usually win"},{"insert":".\n"},{"attributes":{"bold":true},"insert":"3. Combo Turn: Draw Chain, Storm Line, Pump Line"},{"attributes":{"header":2},"insert":"\n"},{"insert":"Start chaining your massive number of cheap spells.\n\n"},{"attributes":{"bold":true},"insert":"Replacement / Draw Spells"},{"attributes":{"header":3},"insert":"\n"},{"insert":{"card-link":"Crimson Wisps"}},{"insert":", "},{"insert":{"card-link":"Expedite"}},{"insert":", "},{"insert":{"card-link":"Opt"}},{"insert":", "},{"insert":{"card-link":"Preordain"}},{"insert":", "},{"insert":{"card-link":"Gitaxian Probe"}},{"insert":", "},{"insert":{"card-link":"Brainstorm"}},{"insert":", "},{"insert":{"card-link":"Frantic Search"}},{"insert":", etc.\n → They replace themselves.\n → Vivi triggers and grows.\n → With cost reduction, many of them cost "},{"attributes":{"bold":true},"insert":"0 mana"},{"insert":" during the combo turn.\n"},{"attributes":{"bold":true},"insert":"Copy Effects"},{"attributes":{"header":3},"insert":"\n"},{"insert":{"card-link":"Reiterate"}},{"insert":", "},{"insert":{"card-link":"Bonus Round"}},{"insert":", "},{"insert":{"card-link":"Display of Power"}},{"insert":", "},{"insert":{"card-link":"Flare of Duplication"}},{"insert":", "},{"insert":{"card-link":"Harmonic Prodigy"}},{"insert":", "},{"insert":{"card-link":"Marvin, Murderous Mimic"}},{"insert":", "},{"insert":{"card-link":"Veyran, Voice of Duality"}},{"insert":"\n → Multiply value, triggers, and mana.\n\n"},{"attributes":{"bold":true},"insert":"Mana Explosion"},{"attributes":{"header":3},"insert":"\n"},{"insert":{"card-link":"Storm-Kiln Artist"}},{"insert":", "},{"insert":{"card-link":"Runaway Steam-Kin"}},{"insert":", "},{"insert":{"card-link":"Seething Song"}},{"insert":", "},{"insert":{"card-link":"Mana Geyser"}},{"insert":", \n → Practical unlimited mana during the combo turn.\n\n"},{"attributes":{"bold":true},"insert":"Convergence Points: Actual Win Paths"},{"attributes":{"header":3},"insert":"\n"},{"attributes":{"bold":true},"insert":"A. Storm Finish"},{"insert":"\n\n"},{"insert":{"card-link":"Mind's Desire"}},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":{"card-link":"Bonus Round"}},{"insert":" + "},{"insert":{"card-link":"Reiterate"}},{"insert":" loops"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":{"card-link":"Mizzix's Mastery"}},{"insert":" as pseudo-storm"},{"attributes":{"list":"bullet"},"insert":"\n"},{"attributes":{"bold":true},"insert":"B. Draw Loops → Direct Damage"},{"insert":"\n\n"},{"insert":{"card-link":"Niv-Mizzet, Parun"}},{"insert":" kills the table once loops start"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":{"card-link":"Curiosity"}},{"insert":" / "},{"insert":{"card-link":"Ophidian Eye"}},{"insert":" / "},{"insert":{"card-link":"Tandem Takedown"}},{"insert":"  = infinite triggers"},{"attributes":{"list":"bullet"},"insert":"\n"},{"attributes":{"bold":true},"insert":"C. "},{"attributes":{"bold":true},"insert":{"card-link":"Vivi Ornitier"}},{"attributes":{"bold":true},"insert":"  Becomes the Wincon"},{"insert":"\n Dozens of spell triggers → Vivi grows to lethal damage output.\n"},{"attributes":{"bold":true},"insert":"D. "},{"attributes":{"bold":true},"insert":{"card-link":"Ojer Axonil, Deepest Might // Temple of Power"}},{"attributes":{"bold":true},"insert":" Shortcut"},{"insert":"\n All "},{"insert":{"card-link":"Vivi Ornitier"}},{"insert":"  damage becomes "},{"attributes":{"bold":true},"insert":"minimum 4"},{"insert":".\n 20+ "},{"insert":{"card-link":"Vivi Ornitier"}},{"insert":"  triggers = lethal for the entire table.\n"},{"attributes":{"bold":true},"insert":"E. Omniscience"},{"insert":"\n Once resolved, you simply unload your entire hand/library.\n"},{"attributes":{"bold":true},"insert":"4. Concrete Win Lines"},{"attributes":{"header":2},"insert":"\n"},{"attributes":{"bold":true},"insert":"1. "},{"attributes":{"bold":true},"insert":{"card-link":"Bonus Round"}},{"attributes":{"bold":true},"insert":"  → cantrip chain → exponential Vivi scaling."},{"insert":"\n"},{"attributes":{"bold":true},"insert":"2. "},{"attributes":{"bold":true},"insert":{"card-link":"Reiterate"}},{"attributes":{"bold":true},"insert":"  + "},{"attributes":{"bold":true},"insert":{"card-link":"Seething Song"}},{"attributes":{"bold":true},"insert":" = Infinite Mana"},{"insert":"\n → Infinite spells for "},{"insert":{"card-link":"Vivi Ornitier"}},{"insert":" \n → Infinite "},{"insert":{"card-link":"Storm-Kiln Artist"}},{"insert":"  triggers\n → Infinite "},{"insert":{"card-link":"Vivi Ornitier"}},{"insert":"  or "},{"insert":{"card-link":"Niv-Mizzet, Parun"}},{"insert":"  damage.\n"},{"attributes":{"bold":true},"insert":"3. Display of Power into a Bonus Round stack"},{"insert":"\n → Triple copies → massive storm → "},{"insert":{"card-link":"Mind's Desire"}},{"insert":"  \n"},{"attributes":{"bold":true},"insert":"4. "},{"attributes":{"bold":true},"insert":{"card-link":"Vivi Ornitier"}},{"attributes":{"bold":true},"insert":"  + "},{"attributes":{"bold":true},"insert":{"card-link":"Curiosity"}},{"attributes":{"bold":true},"insert":" / "},{"attributes":{"bold":true},"insert":{"card-link":"Ophidian Eye"}},{"attributes":{"bold":true},"insert":" / "},{"attributes":{"bold":true},"insert":{"card-link":"Tandem Lookout"}},{"insert":"\n → Damage draws cards → draws cast spells → spells deal damage\n → Fully self-sustaining loop.\n"},{"attributes":{"bold":true},"insert":"5. Playstyle"},{"attributes":{"header":2},"insert":"\n"},{"insert":"This is a "},{"attributes":{"bold":true},"insert":"control-storm hybrid"},{"insert":":\n\nYou don’t need mass removal; "},{"insert":{"card-link":"Cyclonic Rift"}},{"insert":" is your only real reset."},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"You wait for the exact turn cycle where nobody can meaningfully interact."},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"Then you unload, generate storm/mana/card advantage, and win in one go."},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"The deck is designed to avoid “forced” storm turns; your engines make the combo turn naturally self-sustaining.\n\n\n\n"},{"attributes":{"bold":true},"insert":"You call this SEMI-BUDGET?!"},{"attributes":{"header":2},"insert":"\n"},{"insert":"I specifically addressed this in a comment below. I hope that this is reasonable.\n"}]}
