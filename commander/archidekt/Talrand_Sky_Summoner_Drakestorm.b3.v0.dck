Description={"ops":[{"insert":"Date of Creation:\n2013"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"\nTheme:\nCantripping into drakes"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"\nPower: \nNot super fast but can get inevitable around turn 8"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"\nWin conditions:\nGenerally drake tokens made via casting a ton of cheap cantrips, often buffed with things like "},{"insert":{"card-link":"Gravitational Shift"}},{"insert":" "},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"\nRules and notes:\nNo infinites"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"\nChangelog:\n2020 02-11 add "},{"insert":{"card-link":"Reset"}},{"insert":" rmv "},{"insert":{"card-link":"Merchant Scroll"}},{"insert":"  (0)"},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 02-11 add "},{"insert":{"card-link":"Dig Through Time"}},{"insert":" rmv "},{"insert":{"card-link":"The Magic Mirror"}},{"insert":" (+1)"},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 02-27 add "},{"insert":{"card-link":"Castle Vantress"}},{"insert":" rmv "},{"insert":{"card-link":"Snow-Covered Island"}},{"insert":" I think I can go down 1 island for Castle (0)"},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 02-27 add "},{"insert":{"card-link":"Coat of Arms"}},{"insert":" rmv "},{"insert":{"card-link":"Snow-Covered Island"}},{"insert":" 2.4 avc CMC, ton of filtering, let's see if 34 lands is ok (+5)"},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 02-27 add "},{"insert":{"card-link":"Wasteland"}},{"insert":" rmv "},{"insert":{"card-link":"Tectonic Edge"}},{"insert":" Found a Wasteland I wasn't using (CMC 0)"},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 03-13 add "},{"insert":{"card-link":"Throne of the God-Pharaoh"}},{"insert":" rmv "},{"insert":{"card-link":"Future Sight"}},{"insert":" Looking for non-combat options to deal damage/win (-3)"},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 04-14 add "},{"insert":{"card-link":"Veilstone Amulet"}},{"insert":" rmv "},{"insert":{"card-link":"Midnight Clock"}},{"insert":" The unpredictability of Clock was frustrating, want some protection (0)"},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 04-14 add "},{"insert":{"card-link":"Reconnaissance Mission"}},{"insert":" rmv "},{"insert":{"card-link":"Reset"}},{"insert":" Reset was just fine, Bident and Coastal Piracy are almost always good (+2)"},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 04-14 add "},{"insert":{"card-link":"Fierce Guardianship"}},{"insert":" rmv "},{"insert":{"card-link":"Ponder"}},{"insert":" Need more protection for Talrand (+2)"},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 06-18 add "},{"insert":{"card-link":"Teferi's Ageless Insight"}},{"insert":" rmv "},{"insert":{"card-link":"Throne of the God-Pharaoh"}},{"insert":" Throne was win-more (+2)"},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 08-04 add "},{"insert":{"card-link":"Fumble"}},{"insert":" rmv "},{"insert":{"card-link":"Quicken"}},{"insert":" Not many sorceries and wanna test Fumble (+1)"},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 09-12 add "},{"insert":{"card-link":"Blink of an Eye"}},{"insert":" rmv "},{"insert":{"card-link":"Boomerang"}},{"insert":" Rarely used Boomerang to hit lands, this is easier to cast (0)"},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 10-13 add "},{"insert":{"card-link":"Sea Gate Restoration // Sea Gate, Reborn"}},{"insert":" rmv "},{"insert":{"card-link":"Terrain Generator"}},{"insert":" Generator just felt a little slow (0)"},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 11-07 add "},{"insert":{"card-link":"War Room"}},{"insert":" rmv "},{"insert":{"card-link":"Castle Vantress"}},{"insert":" War Room is just a better Castle (0)"},{"attributes":{"list":"or