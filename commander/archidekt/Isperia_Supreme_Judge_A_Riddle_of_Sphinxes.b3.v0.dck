Description={"ops":[{"insert":"Date of creation\n2014"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"\nTheme:\nSphinxs in a moderate control shell"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"\nPower\nFairly slow, won't win before turn 10, but it can usually last to that point then turn the corner"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"\nWin conditions:\nUsual win condition is sphinx beats, often enabled by things like "},{"insert":{"card-link":"True Conviction"}},{"insert":" "},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"\nRules:\nOnly sphinx as creatures or walkers"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"No infinites"},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"\nChangelog:\n2020 01-11 add "},{"insert":{"card-link":"Dream Trawler"}},{"insert":" rmv "},{"insert":{"card-link":"Sphinx of Lost Truths"}},{"insert":"  Come on, Dream Trawler is dope af"},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 01-29 add "},{"insert":{"card-link":"Arcane Denial"}},{"insert":" rmv "},{"insert":{"card-link":"Render Silent"}},{"insert":" Deck is so mana hungry, need easier to cast counters"},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 01-29 add "},{"insert":{"card-link":"Thought Vessel"}},{"insert":" rmv "},{"insert":{"card-link":"Mana Crypt"}},{"insert":" Deck isn't a Mana Crypt deck and I'm not a Mana Crypt guy"},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 02-20 add "},{"insert":{"card-link":"Prognostic Sphinx"}},{"insert":" rmv "},{"insert":{"card-link":"Chancellor of the Spires"}},{"insert":" Chancy has just been ineffective too often"},{"attributes":{"list":"ordered"},"insert":"\n"},{"insert":"2020 03-27 add "},{"insert":{"card-link":"Dust Bowl"}},{"insert":" rmv "},{"insert":{"card-link":"Temple of Enlightenment"}},{"insert":" Trying to make sure I'm at 3 land removal lands"},{"attributes":{"list":"ordered"},"insert":"\n"},{"i